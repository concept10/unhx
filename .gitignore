# UNHOX .gitignore

# Build artifacts
build/
*.o
*.a
*.so
*.elf
*.bin
*.iso
*.img

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# Nix
result
result-*
.direnv/

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Cross-compiler build outputs
cross/build/

# QEMU disk images (large, generated)
*.qcow2
*.raw

# Archive downloads (large, binary)
archive/cmu-mach/*.tar*
archive/osf-mk/*.tar*
archive/utah-oskit/*.tar*
